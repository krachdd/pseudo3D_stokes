[Grid]
UpperRight = 0.0004 0.0004
Cells = 400 400
Periodic = 0 1 # x y (z) 1 -> periodic; 0 -> not periodic

GeometryFile = pipesPeriodic.pgm
PreFactorDragFileX = noFile
PreFactorDragFileY = noFile

[Problem]
Name = pipesPeriodic
DeltaP = 0.0014 # [Pa] Pressure difference between inlet and outlet  
pRef = 0          # [Pa] Reference pressure at the outlet
EnableGravity = false
Height = 3.6e-05 # [m]              # 
PseudoWallFractionFactor = 12        # 8 for v_max, 12 for v_average
AddPressureCorrection = true         # true -> brinkman, false -> stokes

[SpatialParams]
PreExtrusionFactor = 1    # 0.666666667 for v_max, 1 for v_average

[Component]
LiquidDensity = 1e3
LiquidKinematicViscosity = 1e-6

[Newton]
MaxSteps = 6
MaxRelativeShift = 1e-8

[Assembly]
NumericDifference.BaseEpsilon = 1e-8

[Vtk]
WriteFaceData = false
WriteVtuData = True
